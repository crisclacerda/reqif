              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Indexes specification text for fast full-text search queries.</xhtml:p>
<xhtml:p><xhtml:strong>Implementation:</xhtml:strong> SQLite FTS5 virtual tables populated during EMIT phase.</xhtml:p>
<xhtml:p><xhtml:strong>Usage:</xhtml:strong> Web application uses FTS for search functionality.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Database">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
