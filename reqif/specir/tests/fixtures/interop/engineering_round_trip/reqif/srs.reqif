            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-08a35293e09f508494096c1c1b3819edb9df50db" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="High-Level Requirement">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-HLR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="High-Level Requirement">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>top-level functional or non-functional requirement</xhtml:strong> that captures what the system must do or satisfy.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="HLR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Defines system-level requirements that guide design and implementation.</xhtml:p>
<xhtml:p><xhtml:strong>Traceability:</xhtml:strong> HLRs trace to verification cases (VC) and are realized by functional descriptions (FD).</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="High-Level Requirement">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-215bb47da8fac3342b858ac3db09b033c6c46e0b" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Intermediate Representation">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-IR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Intermediate Representation">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>The <xhtml:strong>database-backed representation</xhtml:strong> of parsed document content.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="IR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Stores parsed specification content in queryable form.</xhtml:p>
<xhtml:p><xhtml:strong>Storage:</xhtml:strong> SQLite database with spec_objects, spec_floats, spec_relations tables.</xhtml:p>
<xhtml:p><xhtml:strong>Lifecycle:</xhtml:strong> Populated during INITIALIZE, queried and modified through remaining phases.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Intermediate Representation">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-8e63fd3e77796b102589b1ba1e4441c7982e4132" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Project Identifier">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-PID">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Project Identifier">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>unique identifier</xhtml:strong> assigned to spec objects for cross-referencing (e.g., <xhtml:code>@REQ-001</xhtml:code>).</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="PID">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Provides unique, human-readable identifiers for traceability and cross-referencing.</xhtml:p>
<xhtml:p><xhtml:strong>Syntax:</xhtml:strong> Written as <xhtml:code>@PID</xhtml:code> in header text (e.g., <xhtml:code>## HLR: Requirement Title @REQ-001</xhtml:code>).</xhtml:p>
<xhtml:p><xhtml:strong>Auto-generation:</xhtml:strong> PIDs can be auto-generated from type prefix and sequence number.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Project Identifier">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-6fb84aed32facd1299ee1e77c8fd2b1a6352669e" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Proof View">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-PROOF">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Proof View">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>SQL query</xhtml:strong> that validates data integrity constraints during the VERIFY phase.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="-">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Defines validation rules as SQL queries that detect specification errors.</xhtml:p>
<xhtml:p><xhtml:strong>Execution:</xhtml:strong> Run during the VERIFY phase; violations are reported as diagnostics.</xhtml:p>
<xhtml:p><xhtml:strong>Examples:</xhtml:strong> Missing required attributes, unresolved relations, cardinality violations.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Proof View">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-812ed4562d3211363a7b813aa9cd2cf042b63bb2" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="SQLite Database">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-SQLITE">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SQLite Database">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>The <xhtml:strong>embedded database engine</xhtml:strong> storing the IR and build cache.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="-">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Provides persistent, portable storage for the intermediate representation.</xhtml:p>
<xhtml:p><xhtml:strong>Benefits:</xhtml:strong> Single-file storage, ACID transactions, SQL query capability.</xhtml:p>
<xhtml:p><xhtml:strong>Usage:</xhtml:strong> All pipeline phases read/write to SQLite via the database manager.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Database">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SQLite Database">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-31bd9b9f5f7b338e41b56183a2f3008b541d7c84" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Traceable Object">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-TRACEABLE">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Traceable Object">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>specification object</xhtml:strong> that participates in traceability relationships.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="-">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Base type for objects that can be linked via traceability relations.</xhtml:p>
<xhtml:p><xhtml:strong>Types:</xhtml:strong> Any spec object type registered in the model (e.g., HLR, LLR, SECTION).</xhtml:p>
<xhtml:p><xhtml:strong>Relations:</xhtml:strong> Model-defined relation types (e.g., XREF_FIGURE, XREF_CITATION) inferred by specificity matching.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Traceable Object">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-9a79be611e0267e1d943da0737c6c51be67865a0" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Type">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-TYPE">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Type">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>category definition</xhtml:strong> that governs behavior for objects, floats, relations, or views.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="-">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Defines the schema, validation rules, and rendering behavior for a category of elements.</xhtml:p>
<xhtml:p><xhtml:strong>Categories:</xhtml:strong> Object types (HLR, SECTION), float types (FIGURE, TABLE), relation types (TRACES_TO), view types (TOC, LOF).</xhtml:p>
<xhtml:p><xhtml:strong>Registration:</xhtml:strong> Types are loaded from model directories and stored in the type registry.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Type">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-310b86e0b62b828562fc91c7be5380a992b2786a" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Verification Case">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-VC">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Verification Case">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>test specification</xhtml:strong> that verifies a requirement or set of requirements.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="VC">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Defines how requirements are verified through test procedures and expected results.</xhtml:p>
<xhtml:p><xhtml:strong>Traceability:</xhtml:strong> VCs trace to HLRs via <xhtml:code>traceability</xhtml:code> attribute links.</xhtml:p>
<xhtml:p><xhtml:strong>Naming:</xhtml:strong> VC PIDs follow the pattern <xhtml:code>VC-{category}-{seq}</xhtml:code> (e.g., <xhtml:code>VC-PIPE-001</xhtml:code>).</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Verification Case">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-dbc0f004854457f59fb16ab863a3a1722cef553f" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Composite Object Type">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-COMPOSITE">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Composite Object Type">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>spec object type</xhtml:strong> whose instances receive hierarchical PIDs qualified by the parent specification PID.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Distinguishes object types that represent document structure (e.g., SECTION) from traceable types that receive standalone PIDs (e.g., HLR, VC).</xhtml:p>
<xhtml:p><xhtml:strong>PID behavior:</xhtml:strong> Composite objects get hierarchical PIDs derived from the specification PID (e.g., <xhtml:code>SRS-sec1.2.3</xhtml:code>). Non-composite objects get independent PIDs from their <xhtml:code>pid_prefix</xhtml:code> and <xhtml:code>pid_format</xhtml:code> (e.g., <xhtml:code>HLR-001</xhtml:code>).</xhtml:p>
<xhtml:p><xhtml:strong>Configuration:</xhtml:strong> Set via <xhtml:code>is_composite = true</xhtml:code> in the type definition module.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Composite Object Type">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-c8306ae139ac98f432932286151dc0ec55580eca" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Relation Selector">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-SELECTOR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Relation Selector">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>The <xhtml:strong>URL scheme portion</xhtml:strong> of a Markdown link that drives relation type inference.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Identifies what kind of relation a Markdown link represents, enabling type-driven inference.</xhtml:p>
<xhtml:p><xhtml:strong>Selectors:</xhtml:strong> <xhtml:code>@</xhtml:code> (PID reference, e.g., <xhtml:code>[HLR-001](@)</xhtml:code>), <xhtml:code>#</xhtml:code> (label reference, e.g., <xhtml:code>[fig:diagram](#)</xhtml:code>), <xhtml:code>@cite</xhtml:code> (bibliographic citation).</xhtml:p>
<xhtml:p><xhtml:strong>Configuration:</xhtml:strong> Each relation type declares a <xhtml:code>link_selector</xhtml:code> value in <xhtml:code>spec_relation_types</xhtml:code>. Selectors are model-defined, not hardcoded.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Relation Selector">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-934385f53d1bd0c1b8493e44d0dfd4c8e88a04bb" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Specificity Scoring">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-SPECIFICITY">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Specificity Scoring">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>The <xhtml:strong>constraint-matching score</xhtml:strong> used to select the best relation type during type inference.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Resolves ambiguity when multiple relation types match a given link by selecting the most specific type.</xhtml:p>
<xhtml:p><xhtml:strong>Algorithm:</xhtml:strong> Each non-NULL constraint match across four dimensions (selector, source_attribute, source_type, target_type) adds one point. The highest total score wins. Ties mark the relation as ambiguous.</xhtml:p>
<xhtml:p><xhtml:strong>Example:</xhtml:strong> A relation type with constraints on selector + source_type + target_type (score 3) wins over one with only selector (score 1).</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Specificity Scoring">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-78a8efcbaaa1a9a30f9f327aa89d0b6acaaffb03" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Processed Intermediate Representation">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-PIR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Processed Intermediate Representation">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>The <xhtml:strong>complete specification state</xhtml:strong> after all pipeline phases have executed, captured as a hash for output cache invalidation.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="P-IR">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Provides a single hash that represents the fully processed state of a specification, including all resolved relations, materialized views, and transformed content.</xhtml:p>
<xhtml:p><xhtml:strong>Usage:</xhtml:strong> The output cache stores the P-IR hash alongside each generated output file. When rebuilding, the system compares the current P-IR hash to the cached hash to determine if output regeneration is needed.</xhtml:p>
<xhtml:p><xhtml:strong>Distinction:</xhtml:strong> Unlike the build cache (which tracks source file hashes), the P-IR hash captures the post-processing state, detecting changes from cross-document operations.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Processed Intermediate Representation">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-e114c448f4ab8554ad14eff3d66dfeb3965ce8fc" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Newline-Delimited JSON">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-NDJSON">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Newline-Delimited JSON">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>text format</xhtml:strong> where each line is a valid JSON object, used for structured log output.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="NDJSON">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-6cd294fe8d31d188a088b5bb0391df9a516db4f5</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Provides machine-parseable structured logging suitable for CI/CD log aggregation and filtering with tools like <xhtml:code>jq</xhtml:code>.</xhtml:p>
<xhtml:p><xhtml:strong>Format:</xhtml:strong> One JSON object per line with fields: <xhtml:code>level</xhtml:code>, <xhtml:code>message</xhtml:code>, <xhtml:code>timestamp</xhtml:code>, and optional context fields.</xhtml:p>
<xhtml:p><xhtml:strong>Usage:</xhtml:strong> The logger emits NDJSON when output is not connected to a TTY (e.g., piped to a file or running in CI).</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Infrastructure">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Newline-Delimited JSON">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-7224f997fc148baa0b7f81c1eda6fcc3fd003db0" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Proof Policy">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-PROOFPOLICY">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Proof Policy">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>configuration mapping</xhtml:strong> from proof view <xhtml:code>policy_key</xhtml:code> to severity level, controlling which violations are reported and at what severity.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Allows projects to control validation strictness by mapping each proof view to a severity level.</xhtml:p>
<xhtml:p><xhtml:strong>Severity levels:</xhtml:strong> <xhtml:code>error</xhtml:code> (blocks output generation), <xhtml:code>warn</xhtml:code> (reported but build continues), <xhtml:code>ignore</xhtml:code> (suppressed).</xhtml:p>
<xhtml:p><xhtml:strong>Configuration:</xhtml:strong> Set in the <xhtml:code>validation:</xhtml:code> section of <xhtml:code>project.yaml</xhtml:code> (e.g., <xhtml:code>traceability_hlr_to_vc: warn</xhtml:code>).</xhtml:p>
<xhtml:p><xhtml:strong>Default:</xhtml:strong> When a policy_key is not configured, the system applies its built-in default severity.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Proof Policy">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-524e05dc77239f3a15dab766aaa59a9e432efde7" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Diagnostic Record">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-DIAGNOSTIC">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Diagnostic Record">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>structured error or warning record</xhtml:strong> emitted by <xhtml:a href="#TERM-16">TERM-16</xhtml:a>s during <xhtml:a href="#TERM-15">TERM-15</xhtml:a> processing.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Provides machine-parseable and human-readable feedback on specification errors and warnings throughout all pipeline phases.</xhtml:p>
<xhtml:p><xhtml:strong>Fields:</xhtml:strong> Each record contains <xhtml:code>file</xhtml:code> (source path), <xhtml:code>line</xhtml:code> (source line number), <xhtml:code>code</xhtml:code> (domain-prefixed identifier, e.g., <xhtml:code>SD-301</xhtml:code>), and <xhtml:code>msg</xhtml:code> (human-readable description).</xhtml:p>
<xhtml:p><xhtml:strong>Severity:</xhtml:strong> Errors trigger abort after <xhtml:a href="#TERM-21">TERM-21</xhtml:a> phase; warnings are reported but do not block output generation.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Core">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Diagnostic Record">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-17503a6b2326f09fbc4e3a7c03874c7333002038" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Build Graph">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-BUILDGRAPH">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Build Graph">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>dependency tracking structure</xhtml:strong> recording include file hierarchies for incremental rebuild support.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Tracks which files are included by each root document, enabling change detection across include hierarchies.</xhtml:p>
<xhtml:p><xhtml:strong>Storage:</xhtml:strong> Stored in the <xhtml:code>build_graph</xhtml:code> table with columns <xhtml:code>root_path</xhtml:code> (the including document), <xhtml:code>node_path</xhtml:code> (the included file), and <xhtml:code>node_sha1</xhtml:code> (content hash at build time).</xhtml:p>
<xhtml:p><xhtml:strong>Usage:</xhtml:strong> Queried by <xhtml:a href="#TERM-30">TERM-30</xhtml:a> <xhtml:code>is_document_dirty_with_includes()</xhtml:code> to determine if any included file has changed since the last successful build.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Database">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Build Graph">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="_SO-a1422e6a168630cdd214ac5e31ca01ae1bee8d92" LAST-CHANGE="2026-03-22T20:31:56.710-03:00" LONG-NAME="Placeholder Block">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="TERM-PLACEHOLDERBLOCK">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-b28c62831982aba7cbe6c7eef408e289bc2065c0</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Placeholder Block">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-147d91306816732e79b47bc00cd0ee89cf55f661</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-689812bda83eb340b364f64252a1913e5f671786</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p>A <xhtml:strong>CodeBlock marker</xhtml:strong> inserted during document assembly for deferred <xhtml:a href="#SpecIR-03">SpecIR-03</xhtml:a> and <xhtml:a href="#SpecIR-06">SpecIR-06</xhtml:a> resolution.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-XHTML>
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-XHTML-REF>_AD-41bf339dae9c0826495c2ef3b7f4618a92e16576</ATTRIBUTE-DEFINITION-XHTML-REF>
              </DEFINITION>
              <THE-VALUE><xhtml:div><xhtml:p><xhtml:strong>Purpose:</xhtml:strong> Marks positions in the assembled Pandoc document where floats and views will be substituted during the <xhtml:a href="#TERM-23">TERM-23</xhtml:a> phase.</xhtml:p>
<xhtml:p><xhtml:strong>Mechanism:</xhtml:strong> During assembly, <xhtml:a href="sdd.ext#CSU-034">CSU-034</xhtml:a> inserts CodeBlock elements at the correct <xhtml:code>file_seq</xhtml:code> positions. Downstream handlers (<xhtml:a href="sdd.ext#CSU-035">CSU-035</xhtml:a> for floats, <xhtml:a href="sdd.ext#CSU-036">CSU-036</xhtml:a> for views) match these placeholders by label and replace them with rendered content.</xhtml:p>
<xhtml:p><xhtml:strong>Lifecycle:</xhtml:strong> Created during assembly, consumed during float/view emission, never present in final output.</xhtml:p></xhtml:div></THE-VALUE>
            </ATTRIBUTE-VALUE-XHTML>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Pipeline">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-4cb12ca163137d97be178997d244f97a6a329c48</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Placeholder Block">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>_AD-2ca7f273391d69cf9a9e2f7558132ed5c588ecec</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>_SOT-f5af52121edcc786da014f780bec04c81b8660e7</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
      </SPEC-OBJECTS>
