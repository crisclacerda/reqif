            </ATTRIBUTE-DEFINITION-XHTML>
            <ATTRIBUTE-DEFINITION-ENUMERATION IDENTIFIER="_AD-80e5e08ac55311d206265d2f06f28de0bd3d0643" LONG-NAME="verification_method">
              <TYPE>
                <DATATYPE-DEFINITION-ENUMERATION-REF>_DT-6af92b7aa52783f654236e5d632aeb125e592721</DATATYPE-DEFINITION-ENUMERATION-REF>
