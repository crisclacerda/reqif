        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-b002cca4-6fe4-4791-8cac-651fcd0f32d6" LAST-CHANGE="2026-03-25T23:43:45Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-LLR-196">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Active">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_STATUS</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Identical Markdown content by import/export roundtrip">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall ensure that identical Markdown content is produced every time StrictDoc reads a Markdown file and then writes it to another Markdown file.\n\nThe following aspects shall additionally apply:\n\n- For MVP, line-endings should support both LF (Linux/macOS-style) and CRLF (Windows-style).\n- The ``export --formats=markdown`` shall work for any format readable by StrictDoc, including Markdown itself, SDoc, RDF (future growth), ReqIF, etc.\n\nNOTE: The write-back to Markdown file must happen through proper AST serialization, not just by giving back the original read Markdown source.\n\nExceptions:\n\nEdge cases related to handling non-default input formats are postponed after the Markdown MVP is implemented. For example:\n\n- Markdown reader encounters content format #3 (implicit field) via [LINK: SDOC-LLR-185], but writer always emits #1/#2 for content via [LINK: SDOC-LLR-198]. In this case the content will not be identical, but it is accepted for an MVP implementation.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="A consistent import/export roundtrip implementation and testing reduces the risk of the Markdown bi-directional import/export corruption.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-4054b864-e9fb-4984-9f36-f1436c161fcc" LAST-CHANGE="2026-03-25T23:43:45Z">
