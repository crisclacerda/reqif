          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-9f0d2713-d591-4eb8-8ab3-2658d827e70a" LAST-CHANGE="2026-03-25T23:43:45Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-LLR-186">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Active">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_STATUS</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Meta fields vs content fields">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall recognize the following Markdown nodes as SDoc nodes:\n\n.. code-block:: markdown\n\n    ### Node title\n    (empty line)\n    **Meta field name 1**:\n    **Meta field name 2**:\n    ...\n    (empty line)\n    **Note content field 1**: ...\n    (empty line)\n    **Note content field 2**: ...\n    ...\n\nAn SDoc node terminates when another Markdown section header or an EOF is encountered.\n\nNOTE: There are no limitations to node level. A Markdown node can be at level 2, 3, etc. The level 1 is served for a root document node (document title with optional fields).">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_c6b7ca9391394360a9aed1c333b03c5e</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-37f79369-56ba-4942-93fa-fc8911f657e9" LAST-CHANGE="2026-03-25T23:43:45Z">
