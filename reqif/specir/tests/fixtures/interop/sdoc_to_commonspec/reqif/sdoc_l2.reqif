        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-c75907ff-65e0-4843-9db0-75683b6914ea" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-171">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="File, line and range markers">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall point to lines and line ranges of Rust code by using file, line and range markers.\nThese marker types shall be parsed from `regular line and block comments`_.\n\nNote: File markers may also result from the inner doc comments of the top-level module.\n\n.. _regular line and block comments: https://doc.rust-lang.org/rust-by-example/hello/comment.html#comments">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-dc1c6291-fd1d-48d3-841a-3da13a65a4be" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-172">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Source nodes from doc comments">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="If a Rust doc comments contains custom tags, and the containing Rust source file matches an entry in the\nsource node configuration, StrictDoc shall create document nodes from the custom tags and automatically\nlink the created node with the Rust item targeted by the doc comment.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-1018d483-e85a-4c02-86b4-aefc747d8bb6" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-173">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Forward relations to Rust items">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall support linking from a requirement in SDoc to a language item in Rust code by using a :code:`FILE`\nrelation of type :code:`FUNCTION`. For example\n\n.. code-block:: strictdoc\n\n   [REQUIREMENT]\n   UID: REQ-1\n   - TYPE: File\n     VALUE: file.rs\n     FUNCTION: file::foo\n\nThis shall work for all kinds of Rust items that have a `canonical path`_, including const, enum, fn, mod, static,\nstruct, trait, type, union.\n\n.. _canonical path: https://doc.rust-lang.org/reference/paths.html#canonical-paths">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-fe925463-8936-441f-8446-90bde07169b3" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-174">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Forward relation by canonical path">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The identifier for forward relations shall be the `canonical path`_ as the rustc compiler would set it when invoked for\na single file like\n\n.. code-block:: shell\n\n   rustc --crate-type rlib --emit=obj src/lib.rs\n\nNote: :code:`cargo build` usually result in a different canonical path, since it considers the file position relative to\nthe crate root. Using a single file as root is a simplification, needed because StrictDoc is unaware of the Rust\nfile and directory-based module hierarchy.\n\n.. _canonical path: https://doc.rust-lang.org/reference/paths.html#canonical-paths">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The canonical path of an item can be observed with :code:`objdump -t lib.o --demangle=rust`. For example, given this\nsource file\n\n.. code-block:: rust\n   :number-lines:\n\n   pub mod foo {\n\n       pub trait Foo {\n           fn foo(&amp;self) {}\n       }\n\n       pub struct Bar(i32);\n\n       impl Foo for Bar {\n           fn foo(&amp;self) {}\n       }\n   }\n\n:code:`objdump` will show\n\n.. code-block:: shell\n\n   &lt;lib::foo::Bar as lib::foo::Foo&gt;::foo\n\nAlas, a forward relation would be\n\n.. code-block:: strictdoc\n\n   [REQUIREMENT]\n   UID: REQ-1\n   - TYPE: File\n     VALUE: file.rs\n     FUNCTION: &lt;lib::foo::Bar as lib::foo::Foo&gt;::foo">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_NOTES</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-064fc239-0ccd-4ded-9afb-4226e9710d3a" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-175">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Collapse doc comments">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Multiple scattered doc comments shall be collapsed as done by the rustdoc_ tool when using the collapse-docs option\nto determine the highlight range(s).\n\nFor example, rustdoc would collapse alle these comments into the description of :code:`fn foo()`\n\n.. code-block:: rust\n   :number-lines:\n\n   /// Some\n   /// line\n\n   /// doc,\n\n   /**\n     * and some\n     * block dock,\n     */\n\n   #[doc = &quot;and some&quot;]\n\n   #[doc = &quot;doc attr.&quot;]\n\n   fn foo() {\n   }\n\nIn the given example, the StrictDoc highlight range for the relation marker shall be from line 1 to line 16.\n\n.. _rustdoc: https://github.com/rust-lang/rust/tree/main/src/tools/rustdoc">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-05af785d-e3bd-42fc-b406-b35bdeaa4b1f" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-176">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Rust marker descriptions">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc should use the marker labels as rustdoc_ would set them in the description of a documented node.\n\n.. _rustdoc: https://doc.rust-lang.org/stable/rustdoc/">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-108e896e-f8ee-44f0-9413-faa28388e40d" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-177">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Valid positions of doc comments">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall find doc comments where the language allows_ them and ignore those in other positions.\n\n.. _allows: https://doc.rust-lang.org/reference/attributes.html#r-attributes.allowed-position">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Since doc comments are syntactic sugar for doc attributes, allowed position rules for attributes apply.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_NOTES</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
