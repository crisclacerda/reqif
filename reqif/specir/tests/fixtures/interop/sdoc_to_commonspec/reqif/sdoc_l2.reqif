        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-4253c224-321a-418b-90dc-ab80bd84066a" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-182">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Allowed position for outer docs">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall find outer doc comments in `allowed positions`_ as specified by the Rust language:\n\n- All item_ declarations\n- Most statements\n- Block expressions, but only when they are the outer expression of an\n  expression statement or the final expression of another block expression.\n- Enum variants, struct and union fields\n- Generic lifetime or type parameter\n- Expressions in limited situations\n- Function, closure and function pointer parameters\n\n.. _allowed positions: https://doc.rust-lang.org/reference/attributes.html#r-attributes.allowed-position\n.. _item: https://doc.rust-lang.org/reference/items.html#r-items.syntax">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
