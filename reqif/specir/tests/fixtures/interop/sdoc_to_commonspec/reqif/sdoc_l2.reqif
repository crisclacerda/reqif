        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-46c50c12-19b6-4716-87ef-dc5071f9f71d" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-164">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Auto-scoped relation markers in Rust docs">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="If a StrictDoc relation marker is inside a `Rust doc comment`_, the marker scope shall be set to exact the item the Rust\nlanguage defines as target of the containing doc comment. The :code:`@relation(scope=...)` parameter shall therefore\nbe optional and shall be ignored if provided.\n\n.. code-block:: rust\n   :number-lines:\n\n   /// @relation(REQ-1)\n   impl Foo {\n\n       /// @relation(REQ-2)\n       fn foo() {\n       }\n   }\n\nIn the given example, the first marker shall link REQ-1 to the :code:`impl Foo` implementation,\nhighlighting lines 1 to 7. The second marker shall link REQ-2 to the :code:`fn foo()` function,\nhighlighting lines 4 to 6.\n\n.. _Rust doc comment: https://doc.rust-lang.org/rust-by-example/meta/doc.html#doc-comments">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Note that doc comments are syntactic sugar for `doc attribute`_ s, which shall also be supported.\nTo figure detailed doc comment rules from the rust-lang specification it&#x27;s sometimes useful\nto check for general attribute rules, if explicit doc comment rules are missing.\n\n.. _doc attribute: https://doc.rust-lang.org/rustdoc/write-documentation/the-doc-attribute.html">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_NOTES</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
        <SPEC-OBJECT IDENTIFIER="REQUIREMENT-b21f07ad-0417-4caa-8d2f-d331f501ef97" LAST-CHANGE="2026-03-25T23:43:58Z">
          <VALUES>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="SDOC-SRS-165">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.ForeignID</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Inner doc attributes">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
