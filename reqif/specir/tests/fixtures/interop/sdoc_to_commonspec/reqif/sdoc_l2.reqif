            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Inline links">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="StrictDoc shall support referencing any node by embedding a hyperlink within the text content of another node.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="The inline links do not replace the relations between SDoc nodes. Instead, an inline link could be an easy way to refer from one textual node to a chapter or a document. A common use case is &quot;See section ABC for more details&quot;.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
