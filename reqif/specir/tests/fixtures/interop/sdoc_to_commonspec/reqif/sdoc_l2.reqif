              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_STATUS</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="At least one integration or end-to-end test">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Name</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="Every update to the StrictDoc codebase shall be complemented with a corresponding provision of at least one test as follows:\n\n- For web interface: at least one end-to-end test.\n- For command-line interface: at least one black-box integration test.\n- For internal Python functions: at least one unit test.\n\nNOTE: This requirement implies that no modifications to StrictDoc&#x27;s functionality can be merged unless accompanied by at least one test.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_ReqIF.Text</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
            <ATTRIBUTE-VALUE-STRING THE-VALUE="This requirement ensures that every new feature or a chance in the codebase is covered/stressed by at least one test, according to the change type.">
              <DEFINITION>
                <ATTRIBUTE-DEFINITION-STRING-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c_RATIONALE</ATTRIBUTE-DEFINITION-STRING-REF>
              </DEFINITION>
            </ATTRIBUTE-VALUE-STRING>
          </VALUES>
          <TYPE>
            <SPEC-OBJECT-TYPE-REF>REQUIREMENT_dc65dfe126e94a7e894ca0421cf6849c</SPEC-OBJECT-TYPE-REF>
          </TYPE>
        </SPEC-OBJECT>
